{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/profile/:id", "destination": "https://api.zoovo.eu/functions/v1/og/profile/:id" },
    { "source": "/pet/:id", "destination": "https://api.zoovo.eu/functions/v1/og/pet/:id" },
    { "source": "/post/:id", "destination": "https://api.zoovo.eu/functions/v1/og/post/:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
